{
  "mcpServers": {
    "ig-trading": {
      "command": "node",
      "args": ["path/to/ig-trading-mcp/dist/index.js"],
      "env": {
        "IG_API_KEY": "your-api-key",
        "IG_USERNAME": "your-username",
        "IG_PASSWORD": "your-password",
